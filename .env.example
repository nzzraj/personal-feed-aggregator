# Preferred for Vercel/serverless: Supabase transaction pooler URL
# NOTE: On pooler, username is usually postgres.<project-ref>
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true

# Optional Vercel integration variable; app will try this automatically if DATABASE_URL fails/missing
POSTGRES_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true

# Optional helpers for tenant username fallback on pooler
SUPABASE_PROJECT_REF=[YOUR-PROJECT-REF]
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co

# Environment
NODE_ENV=production
